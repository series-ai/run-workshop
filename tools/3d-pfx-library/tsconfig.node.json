{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true
  },
  "include": ["vite.config.ts", "viewer/scripts"]
}

{
  "name": "3d-pfx-library",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "SEE LICENSE IN ../../LICENSE.md",
  "description": "React Three Fiber particle-effects library (500 ranked presets, GamePfx runtime) with a browser to preview, search and profile effects. Imported from game-bot; effects are authored-preview grade.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "profile": "node --import tsx viewer/scripts/profile-browser.ts --suite representative --output=.profiles/r3f-pfx-browser-profile.json",
    "profile:authored": "node --import tsx viewer/scripts/profile-browser.ts --suite authored --output=.profiles/r3f-pfx-authored-profile.json",
    "profile:profile-backed": "node --import tsx viewer/scripts/profile-browser.ts --suite profile-backed --output=.profiles/r3f-pfx-profile-backed-profile.json",
    "profile:catalog-stress": "node --import tsx viewer/scripts/profile-browser.ts --suite catalog-stress --output=.profiles/r3f-pfx-catalog-stress-profile.json",
    "profile:all": "npm run profile && npm run profile:authored && npm run profile:profile-backed && npm run profile:catalog-stress"
  },
  "dependencies": {
    "@react-three/fiber": "^8.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "~0.170.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "~0.170.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "playwright": "1.59.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}

# Copy to `.env` and fill in only what you need. `.env` is gitignored —
# never commit real keys.
#
# Auth, in short:
#   - Local dev (`npm run dev`): sign in through the sandbox toolbar
#     (Google Sign-In) in the browser. No key required.
#   - Pack authoring (`rundot generate` / tools/generate-kit.ts): run
#     `rundot login` once; the CLI uses the stored session. Do NOT put an
#     API key here for generation.

# OPTIONAL — headless dev-server key for `npm run dev` without a browser
# sign-in (CI / automation). Mint one with `rundot playground`. Leave blank
# for normal local development.
RUNDOT_API_KEY=

# OPTIONAL — pin the sandbox game id passed to `rundot generate --game-id`.
# When blank, `rundot` resolves the game from your logged-in session / local
# rundot config.
RUNDOT_SANDBOX_GAME_ID=

# OPTIONAL dev-server overrides (host / ports). Leave blank for defaults.
DEV_HOST=
DEV_PORT=
MULTIPLAYER_DEV_PORT=
